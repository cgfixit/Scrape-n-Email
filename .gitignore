# ============================================================
# Scrape-n-Email — .gitignore
# Generated: 2026-06-20
# ============================================================

# ------------------------------------------------------------
# Scraped output files (generated by main.py at runtime)
# These are data artifacts, not source — never commit them.
# ------------------------------------------------------------
jobs.txt
RCPheadlines.txt
RCPlinks.csv

# Catch any future scraper output variants
*headlines*.txt
*links*.csv
*jobs*.txt

# ------------------------------------------------------------
# Misc project artifacts
# ------------------------------------------------------------
old

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / build
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Jupyter
.ipynb_checkpoints/

# ------------------------------------------------------------
# Secrets / environment
# (mailer.py already enforces env-var creds — keep them out)
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.env

# ------------------------------------------------------------
# Editor / OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
